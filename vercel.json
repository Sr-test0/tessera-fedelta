{
    "headers": [
          {
                  "source": "/(.*)",
                  "headers": [
                            {
                                        "key": "Content-Security-Policy",
                                        "value": "default-src 'self'; script-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdn.sheetjs.com cdnjs.cloudflare.com; connect-src 'self' *.supabase.co; img-src 'self' data: tessera.sr-art.it; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; frame-ancestors 'none';"
                            },
                            {
                                        "key": "X-Frame-Options",
                                        "value": "DENY"
                            },
                            {
                                        "key": "X-Content-Type-Options",
                                        "value": "nosniff"
                            },
                            {
                                        "key": "Referrer-Policy",
                                        "value": "strict-origin-when-cross-origin"
                            },
                            {
                                        "key": "Permissions-Policy",
                                        "value": "camera=(), microphone=(), geolocation=()"
                            },
                            {
                                        "key": "Strict-Transport-Security",
                                        "value": "max-age=63072000; includeSubDomains; preload"
                            }
                  ]
          }
    ]
}
